# Application
APP_NAME=Research Intelligence MCP
APP_VERSION=0.1.0
APP_ENVIRONMENT=development

# MCP
MCP_SERVER_NAME=research-intelligence-mcp
#
# "stdio" (default) is the local transport used by Claude Desktop, Cursor,
# and MCP Inspector and requires no authentication. "streamable-http" is
# used for remote deployments (e.g. ResearchMind integration) and honors
# the authentication settings below.
MCP_TRANSPORT=stdio

# Bind host/port used only by the streamable-http transport.
MCP_HOST=127.0.0.1
MCP_PORT=8000

# Authentication
#
# See docs/research_intelligence_mcp_authentication.md.
#
# Authentication is only enforced on the streamable-http transport; stdio
# ignores these settings entirely. Leave AUTH_ENABLED=false for local
# development.
AUTH_ENABLED=false

# Expected `iss` claim. Required when AUTH_ENABLED=true.
AUTH_ISSUER=https://auth.researchmind.ai

# Expected `aud` claim. Required when AUTH_ENABLED=true.
AUTH_AUDIENCE=research-intelligence-mcp

# Public URL of this MCP server, used for OAuth protected-resource metadata.
AUTH_RESOURCE_SERVER_URL=

# Comma-separated JWT algorithms this server trusts. Asymmetric algorithms
# (RS256, ES256, PS256) require AUTH_JWKS_URL; HS256 requires AUTH_JWT_SECRET.
AUTH_JWT_ALGORITHMS=RS256

# JWKS endpoint used to verify RS256/ES256/PS256 tokens (production).
AUTH_JWKS_URL=

# Shared secret used to verify HS256 tokens. Local/test environments only.
AUTH_JWT_SECRET=

# Comma-separated scopes a token must carry.
AUTH_REQUIRED_SCOPES=research-intelligence/invoke

# Clock-skew tolerance applied to exp/nbf/iat checks.
AUTH_JWT_LEEWAY_SECONDS=30

# How long fetched JWKS signing keys stay cached.
AUTH_JWKS_CACHE_TTL_SECONDS=300

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=console

# Shared HTTP infrastructure
HTTP_CONNECT_TIMEOUT_SECONDS=5
HTTP_READ_TIMEOUT_SECONDS=20
HTTP_WRITE_TIMEOUT_SECONDS=20
HTTP_POOL_TIMEOUT_SECONDS=5
HTTP_MAX_CONNECTIONS=20
HTTP_MAX_KEEPALIVE_CONNECTIONS=10
HTTP_KEEPALIVE_EXPIRY_SECONDS=30
HTTP_USER_AGENT=research-intelligence-mcp/0.1.0

# Semantic Scholar
#
# Optional. Leave empty for anonymous public API access.
SEMANTIC_SCHOLAR_API_KEY=

SEMANTIC_SCHOLAR_GRAPH_BASE_URL=https://api.semanticscholar.org/graph/v1
SEMANTIC_SCHOLAR_RECOMMENDATIONS_BASE_URL=https://api.semanticscholar.org/recommendations/v1

# Conservative anonymous client-side limit.
SEMANTIC_SCHOLAR_RATE_LIMIT_REQUESTS=1
SEMANTIC_SCHOLAR_RATE_LIMIT_PERIOD_SECONDS=2

SEMANTIC_SCHOLAR_MAX_RETRY_ATTEMPTS=3
SEMANTIC_SCHOLAR_RETRY_MIN_SECONDS=2
SEMANTIC_SCHOLAR_RETRY_MAX_SECONDS=20

# Live tests remain disabled by default.
SEMANTIC_SCHOLAR_LIVE_TESTS=false

# arXiv
ARXIV_BASE_URL=https://export.arxiv.org/api

# arXiv's legacy API terms require no more than one request every
# three seconds and only one connection at a time.
ARXIV_RATE_LIMIT_REQUESTS=1
ARXIV_RATE_LIMIT_PERIOD_SECONDS=3

ARXIV_MAX_RETRY_ATTEMPTS=3
ARXIV_RETRY_MIN_SECONDS=3
ARXIV_RETRY_MAX_SECONDS=30

# Local safety limit. The official API supports larger slices, but MCP
# requests should remain bounded and responsive.
ARXIV_MAX_RESULTS_PER_REQUEST=50

# Live tests remain disabled by default.
ARXIV_LIVE_TESTS=false

CACHE_ENABLED=true

SEARCH_CACHE_MAX_SIZE=500
SEARCH_CACHE_TTL_SECONDS=900

PAPER_CACHE_MAX_SIZE=5000
PAPER_CACHE_TTL_SECONDS=86400