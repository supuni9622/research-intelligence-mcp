{
  "family": "research-intelligence-mcp",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/research-intelligence-mcp-execution-role",
  "taskRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/research-intelligence-mcp-task-role",
  "containerDefinitions": [
    {
      "name": "research-intelligence-mcp",
      "image": "<ACCOUNT_ID>.dkr.ecr.<REGION>.amazonaws.com/research-intelligence-mcp:<IMAGE_TAG>",
      "essential": true,
      "portMappings": [
        {
          "name": "mcp-http",
          "containerPort": 8000,
          "protocol": "tcp",
          "appProtocol": "http"
        }
      ],
      "environment": [
        { "name": "APP_ENVIRONMENT", "value": "production" },
        { "name": "MCP_TRANSPORT", "value": "streamable-http" },
        { "name": "MCP_HOST", "value": "0.0.0.0" },
        { "name": "MCP_PORT", "value": "8000" },
        { "name": "LOG_LEVEL", "value": "INFO" },
        { "name": "LOG_FORMAT", "value": "json" },
        { "name": "AUTH_ENABLED", "value": "true" },
        { "name": "AUTH_ISSUER", "value": "https://auth.researchmind.ai" },
        { "name": "AUTH_AUDIENCE", "value": "research-intelligence-mcp" },
        {
          "name": "AUTH_JWKS_URL",
          "value": "https://auth.researchmind.ai/.well-known/jwks.json"
        },
        { "name": "AUTH_JWT_ALGORITHMS", "value": "RS256" },
        { "name": "AUTH_REQUIRED_SCOPES", "value": "research-intelligence/invoke" }
      ],
      "secrets": [
        {
          "name": "SEMANTIC_SCHOLAR_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:research-intelligence-mcp/semantic-scholar-api-key"
        }
      ],
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "python -c \"import urllib.request as u; u.urlopen('http://127.0.0.1:8000/health', timeout=3)\" || exit 1"
        ],
        "interval": 30,
        "timeout": 5,
        "startPeriod": 10,
        "retries": 3
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/research-intelligence-mcp",
          "awslogs-region": "<REGION>",
          "awslogs-stream-prefix": "research-intelligence-mcp"
        }
      },
      "stopTimeout": 30
    }
  ]
}
